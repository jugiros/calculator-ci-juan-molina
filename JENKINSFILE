pipeline {
    agent any

    stages {

        stage('Get Code') {
            steps {
                git 'https://github.com/jugiros/calculator-ci-juan-molina.git'
            }
        }

        stage('Unit') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    bat '''
                        set PYTHONPATH=%WORKSPACE%
                        python -m pytest --junitxml=result-unit.xml test\\unit
                    '''
                }
            }
            post {
                always {
                    junit 'result-unit.xml'
                }
            }
        }

        stage('Rest') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                    bat '''
                        set FLASK_APP=app\\api.py
                        set FLASK_ENV=development
                        start flask run
                        start java -jar D:\\JUAN\\PROFESIONAL\\UNIR\\wiremock-standalone-3.13.2.jar --port 9090 --root-dir test\\wiremock
                        ping 127.0.0.1 -n 5 > nul
                        set PYTHONPATH=%WORKSPACE%
                        python -m pytest --junitxml=result-rest.xml test\\rest
                    '''
                }
            }
            post {
                always {
                    junit 'result-rest.xml'
                }
            }
        }

        stage('Static') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                    bat '''
                        python -m flake8 --format=pylint --output-file=flake8.txt app || exit 0
                    '''
                }
            }
            post {
                always {
                    recordIssues(
                        tools: [flake8(pattern: 'flake8.txt')],
                        qualityGates: [